{
    "compilerOptions": {
        "outDir": "dist",
        "target": "ES2020",
        "module": "ES2022",
        "lib": ["dom", "es2020"],
        "moduleResolution": "node",
        "esModuleInterop": true,
        "jsx": "react-jsx",
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationDir": "dist/dts",
        "resolveJsonModule": true,
        "strict": true,
        "skipLibCheck": true,
        "baseUrl": "../../",
        "types": ["types-base", "@gdi/types", "@types/jest"],
        "paths": {
            "@gdi/template-basic": ["packages/gdi-template-basic"],
            "@gdi/template-minimalist": ["packages/gdi-template-minimalist"],
            "@gdi/template-blog": ["packages/gdi-template-blog"],
            "@gdi/store-factory": ["packages/gdi-store-factory"]
        }
    },
    "include": ["src/*.ts", "test/*.ts"]
}
