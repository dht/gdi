{
    "compilerOptions": {
        "outDir": "dist",
        "target": "es2016",
        "module": "ESNext",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "jsx": "react-jsx",
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationDir": "dist/dts",
        "strict": true,
        "skipLibCheck": true,
        "baseUrl": "../../",
        "paths": {
            "@gdi/template-gdi": ["packages/gdi-template-gdi"]
        }
    },
    "include": ["src/*.ts", "test/*.ts"]
}
