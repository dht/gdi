        "@fullcalendar/timegrid": "^5.11.3",
        "@gdi/hooks": "^0.0.25",
        "bytes": "^3.1.2",
        "classnames": "^2.3.1",
        "date-fns": "^2.29.1",
        "lodash": "^4.17.21",
        "react-phone-number-input": "^3.2.7",
        "react-select": "^5.4.0",
        "react-social-icons": "^5.14.0",
        "react-toastify": "^9.0.8",
        "react-use": "^17.4.0",
        "styled-components": "^5.3.5"
