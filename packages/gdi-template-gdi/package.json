{
    "name": "@gdi/template-gdi",
    "version": "0.0.65",
    "description": "A template for GDI homepage",
    "scripts": {
        "dev": "vite --config vite.config.serve.js",
        "build": "tsc & vite build",
        "test": "jest",
        "coverage": "jest --coverage=true"
    },
    "author": {
        "name": "dht"
    },
    "dependencies": {
        "shared-base": "^0.0.32",
        "@gdi/engine": "^0.0.86",
        "@gdi/types": "^0.0.105",
        "@gdi/uno": "^0.0.38",
        "@gdi/web-ui": "^0.0.75",
        "classnames": "^2.3.1",
        "igrid": "^0.0.18",
        "polished": "^4.2.2",
        "react-draggable": "^4.4.5",
        "react-router-dom": "^6.3.0",
        "react-use": "^17.4.0",
        "styled-components": "^5.3.5"
    },
    "peerDependencies": {
        "react": "^18.2.0"
    },
    "devDependencies": {
        "@gdi/photo-booth": "^0.0.11",
        "@testing-library/react": "^13.3.0",
        "@types/chance": "^1.1.3",
        "@types/jest": "^28.1.6",
        "@types/react": "^18.0.15",
        "@types/styled-components": "^5.1.26",
        "@vitejs/plugin-react": "^2.2.0",
        "chance": "^1.1.8",
        "jest": "^28.1.3",
        "jest-cli": "^28.1.3",
        "jest-environment-jsdom": "^28.1.3",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "rollup-plugin-analyzer": "^4.0.0",
        "rollup-plugin-copy": "^3.4.0",
        "sass": "^1.54.0",
        "testing-base": "^0.0.4",
        "ts-jest": "^28.0.7",
        "typescript": "^4.7.4",
        "vite": "^3.0.4",
        "vite-plugin-dts": "^1.7.1",
        "vite-tsconfig-paths": "^3.6.0"
    },
    "files": [
        "dist"
    ],
    "main": "./dist/template-gdi.umd.js",
    "module": "./dist/template-gdi.es.js",
    "types": "./dist/dts/src/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/template-gdi.es.js",
            "require": "./dist/template-gdi.umd.js"
        },
        "./dist/public/": {
            "import": "./dist/public/",
            "require": "./dist/public/"
        }
    },
    "gdi": {
        "packageType": "template",
        "templateId": "com.usegdi.templates.gdi",
        "isBeta": false,
        "isDraft": true
    }
}