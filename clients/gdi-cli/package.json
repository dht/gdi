        "copy:collections": "cp -rp ./src/collections/ ./dist/collections/",
        "copy:bin": "cp -rp ./bin/ ./dist/bin/",
        "copy:templates": "cp -rp ./src/templates/ ./dist/templates/",
        "watch": "nodemon -x \"npm run build\""
    },
    "author": "",
    "dependencies": {
