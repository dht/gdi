        "firebase-admin": "^11.3.0",
        "fs-extra": "^9.0.1",
        "globby": "^11.0.2",
        "json-server": "^0.17.1",
        "lodash": "^4.17.21",
        "prettier": "^2.5.1",
        "shared-base": "^0.0.29",
        "yargs": "^17.2.1",
        "yup": "^0.32.11",
        "tsconfig-paths": "^4.1.1"
