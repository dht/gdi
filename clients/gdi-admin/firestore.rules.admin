            allow read: if isAdmin();
            allow write: if isAdmin();
        }

        match /appStateStudio/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

        match /appStateTasks/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

        match /appStateThings/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

        match /appStateVoice/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

        match /authState/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

        match /widgetGalleryState/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

