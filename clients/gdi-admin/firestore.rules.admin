rules_version = '2';
service cloud.firestore {
    match /databases/{database}/documents {  	

        function isAdmin() {
            return get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == "admin";
        }
        
        match /singles/{name} {
            allow read: if isAdmin();
            allow write: if isAdmin();    
        }

        match /appStateBiblo/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

        match /appStateDeb/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

        match /appStateDevtools/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

        match /appStateEvents/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

        match /appStateKnowledge/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

        match /appStateMixer/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

        match /appStateMoney/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

        match /appStatePpl/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

        match /appStateScheduler/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

        match /appStateSoundboard/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

