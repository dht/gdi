            allow write: if isAdmin();
        }

        match /cameras/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

        match /expectedManas/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

        match /grounds/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

        match /images/{document=**} {
            allow read: if isAdmin();
            allow write: if isAdmin();
        }

        match /instancesProps/{document=**} {
