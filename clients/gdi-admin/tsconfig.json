{
    "compilerOptions": {
        "outDir": "dist",
        "target": "es2016",
        "module": "ESNext",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationDir": "dist/dts",
        "strict": true,
        "skipLibCheck": true,
        "types": ["types-base"],
        "jsx": "react-jsx",
        "baseUrl": "../../",
        "paths": {
            "@gdi/app-mixer": ["apps/app-mixer"],
            "@gdi/app-login": ["apps/app-login"],
            "@gdi/store-auth": ["packages/gdi-store-auth"],
            "@gdi/store-mixer": ["packages/gdi-store-mixer"],
            "@gdi/store-site": ["packages/gdi-store-site"],
            "@gdi/template-gdi": ["packages/gdi-template-gdi"],
            "@gdi/web-base-ui": ["packages/gdi-web-base-ui"],
            "@gdi/web-ui": ["packages/gdi-web-ui"],
            "@gdi/web-forms": ["packages/gdi-web-forms"],
            "@gdi/platformer": ["packages/platformer"],
            "@gdi/engine": ["packages/gdi-engine"],
            "redux-connected": ["submodules/redux-connected"],
            "igrid": ["submodules/igrid"]
        }
    },
    "include": ["src-admin/*.ts", "test/*.ts"]
}
