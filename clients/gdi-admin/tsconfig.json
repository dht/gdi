{
    "compilerOptions": {
        "outDir": "dist",
        "target": "es2017",
        "module": "ESNext",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationDir": "dist/dts",
        "strict": true,
        "skipLibCheck": true,
        "types": ["types-base", "@gdi/types", "@types/jest"],
        "jsx": "react-jsx",
        "baseUrl": "../../",
        "paths": {
            "@gdi/app-biblo": ["apps/app-biblo"],
            "@gdi/app-debdb": ["apps/app-debdb"],
            "@gdi/app-devtools": ["apps/app-devtools"],
            "@gdi/app-events": ["apps/app-events"],
            "@gdi/app-knowledge": ["apps/app-knowledge"],
            "@gdi/app-login": ["apps/app-login"],
            "@gdi/app-mixer": ["apps/app-mixer"],
            "@gdi/app-money": ["apps/app-money"],
            "@gdi/app-ppl": ["apps/app-ppl"],
            "@gdi/app-soundboard": ["apps/app-soundboard"],
            "@gdi/app-spotify": ["apps/app-spotify"],
            "@gdi/app-studio": ["apps/app-studio"],
            "@gdi/app-tasks": ["apps/app-tasks"],
            "@gdi/app-things": ["apps/app-things"],
            "@gdi/app-voice": ["apps/app-voice"],

            "@gdi/store-auth": ["stores/gdi-store-auth"],
            "@gdi/store-biblo": ["stores/gdi-store-biblo"],
            "@gdi/store-devtools": ["stores/gdi-store-devtools"],
            "@gdi/store-events": ["stores/gdi-store-events"],
            "@gdi/store-knowledge": ["stores/gdi-store-knowledge"],
            "@gdi/store-mixer": ["stores/gdi-store-mixer"],
            "@gdi/store-money": ["stores/gdi-store-money"],
            "@gdi/store-ppl": ["stores/gdi-store-ppl"],
            "@gdi/store-site": ["stores/gdi-store-site"],
            "@gdi/store-soundboard": ["stores/gdi-store-soundboard"],
            "@gdi/store-studio": ["stores/gdi-store-studio"],
            "@gdi/store-tasks": ["stores/gdi-store-tasks"],
            "@gdi/store-things": ["stores/gdi-store-things"],
            "@gdi/store-voice": ["stores/gdi-store-voice"],

            "@gdi/template-gdi": ["templates/gdi-template-gdi"],
            "@gdi/template-blog": ["templates/gdi-template-blog"],

            "@gdi/web-base-ui": ["packages/gdi-web-base-ui"],
            "@gdi/web-ui": ["packages/gdi-web-ui"],
            "@gdi/galleries": ["packages/gdi-galleries"],
            "@gdi/web-forms": ["packages/gdi-web-forms"],
            "@gdi/platformer": ["packages/platformer"],
            "@gdi/engine": ["packages/gdi-engine"],
            "redux-connected": ["submodules/redux-connected"],
            "shared-base": ["submodules/shared-base"],
            "igrid": ["submodules/igrid"],
            "isokit": ["submodules/isokit"]
        }
    },
    "include": ["src-admin/*.ts", "test/*.ts"]
}
