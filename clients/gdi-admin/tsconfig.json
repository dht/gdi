{
    "compilerOptions": {
        "outDir": "dist",
        "target": "es2017",
        "module": "ESNext",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationDir": "dist/dts",
        "strict": true,
        "skipLibCheck": true,
        "types": ["types-base", "@gdi/types", "@types/jest"],
        "jsx": "react-jsx",
        "baseUrl": "../../",
        "paths": {
            "@gdi/app-login": ["apps/app-login"],
            "@gdi/app-mixer": ["apps/app-mixer"],
            "@gdi/app-biblo": ["submodules/gdi-extra/apps/app-biblo"],
            "@gdi/app-debdb": ["submodules/gdi-extra/apps/app-debdb"],
            "@gdi/app-devtools": ["submodules/gdi-extra/apps/app-devtools"],
            "@gdi/app-events": ["submodules/gdi-extra/apps/app-events"],
            "@gdi/app-knowledge": ["submodules/gdi-extra/apps/app-knowledge"],
            "@gdi/app-money": ["submodules/gdi-extra/apps/app-money"],
            "@gdi/app-ppl": ["submodules/gdi-extra/apps/app-ppl"],
            "@gdi/app-soundboard": ["submodules/gdi-extra/apps/app-soundboard"],
            "@gdi/app-spotify": ["submodules/gdi-extra/apps/app-spotify"],
            "@gdi/app-studio": ["submodules/gdi-extra/apps/app-studio"],
            "@gdi/app-tasks": ["submodules/gdi-extra/apps/app-tasks"],
            "@gdi/app-things": ["submodules/gdi-extra/apps/app-things"],
            "@gdi/app-voice": ["submodules/gdi-extra/apps/app-voice"],

            "@gdi/store-mixer": ["stores/gdi-store-mixer"],
            "@gdi/store-money": ["stores/gdi-store-money"],
            "@gdi/store-auth": ["submodules/gdi-extra/stores/gdi-store-auth"],
            "@gdi/store-biblo": ["submodules/gdi-extra/stores/gdi-store-biblo"],
            "@gdi/store-devtools": [
                "submodules/gdi-extra/stores/gdi-store-devtools"
            ],
            "@gdi/store-events": [
                "submodules/gdi-extra/stores/gdi-store-events"
            ],
            "@gdi/store-knowledge": [
                "submodules/gdi-extra/stores/gdi-store-knowledge"
            ],
            "@gdi/store-ppl": ["submodules/gdi-extra/stores/gdi-store-ppl"],
            "@gdi/store-site": ["stores/gdi-store-site"],
            "@gdi/store-soundboard": [
                "submodules/gdi-extra/stores/gdi-store-soundboard"
            ],
            "@gdi/store-studio": [
                "submodules/gdi-extra/stores/gdi-store-studio"
            ],
            "@gdi/store-tasks": ["submodules/gdi-extra/stores/gdi-store-tasks"],
            "@gdi/store-things": [
                "submodules/gdi-extra/stores/gdi-store-things"
            ],
            "@gdi/store-voice": ["submodules/gdi-extra/stores/gdi-store-voice"],

            "@gdi/template-gdi": ["templates/gdi-template-gdi"],
            "@gdi/template-blog": ["templates/gdi-template-blog"],

            "@gdi/web-base-ui": ["packages/gdi-web-base-ui"],
            "@gdi/web-ui": ["packages/gdi-web-ui"],
            "@gdi/galleries": ["packages/gdi-galleries"],
            "@gdi/web-forms": ["packages/gdi-web-forms"],
            "@gdi/platformer": ["packages/platformer"],
            "@gdi/engine": ["packages/gdi-engine"],
            "redux-connected": ["submodules/redux-connected"],
            "redux-connected-devtools": ["submodules/redux-connected-devtools"],
            "shared-base": ["submodules/shared-base"],
            "igrid": ["submodules/igrid"],
            "isokit": ["submodules/isokit"]
        }
    },
    "include": ["src-admin/*.ts", "test/*.ts"]
}
