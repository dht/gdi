{
    "ts-node": {
        "compilerOptions": {
            "jsx": "react-jsx",
            "module": "CommonJS",
            "allowSyntheticDefaultImports": true,
            "resolveJsonModule": true
        }
    },
    "compilerOptions": {
        "target": "es2017",
        "moduleResolution": "node",
        "skipLibCheck": true,
        "types": ["types-base", "@gdi/types", "@types/jest", "node"]
    }
}
