{
    "compilerOptions": {
        "outDir": "dist",
        "target": "ES2020",
        "module": "ES2022",
        "lib": ["dom", "ES2020"],
        "moduleResolution": "node",
        "esModuleInterop": true,
        "jsx": "react-jsx",
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationDir": "dist/dts",
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "baseUrl": "../../",
        "types": ["types-base", "@gdi/types", "@types/jest"],
        "paths": {
            "@gdi/store-carts": ["stores/gdi-store-carts"]
        }
    },
    "include": ["src/*.ts", "test/*.ts"]
}
